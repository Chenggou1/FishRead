{
  "name": "@fishread/cli",
  "version": "0.1.2",
  "type": "module",
  "description": "FishRead CLI — local EPUB reading runtime",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Chenggou1/FishRead.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/Chenggou1/FishRead#readme",
  "bugs": {
    "url": "https://github.com/Chenggou1/FishRead/issues"
  },
  "keywords": [
    "fishread",
    "cli",
    "reader",
    "novel",
    "epub"
  ],
  "exports": {
    ".": {
      "import": "./index.js",
      "types": "./index.d.ts"
    }
  },
  "types": "index.d.ts",
  "bin": {
    "fishread": "bin/fishread.js"
  },
  "files": [
    "bin/",
    "index.js",
    "index.d.ts"
  ],
  "optionalDependencies": {
    "@fishread/cli-darwin-arm64": "workspace:*",
    "@fishread/cli-darwin-x64": "workspace:*",
    "@fishread/cli-linux-arm64": "workspace:*",
    "@fishread/cli-linux-x64": "workspace:*",
    "@fishread/cli-win32-x64": "workspace:*"
  }
}
