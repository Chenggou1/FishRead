{
  "name": "@fishread/sdk",
  "version": "0.1.1",
  "type": "module",
  "description": "FishRead SDK — shared TypeScript access to the local reading runtime",
  "main": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Chenggou1/FishRead.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/Chenggou1/FishRead#readme",
  "bugs": {
    "url": "https://github.com/Chenggou1/FishRead/issues"
  },
  "keywords": [
    "fishread",
    "sdk",
    "reader",
    "novel",
    "epub"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "src/index.ts",
  "files": [
    "dist/",
    "src/"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@fishread/cli": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "typescript": "^5.0.0"
  }
}
